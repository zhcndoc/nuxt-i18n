d-messages",{"title":97,"path":404,"stem":405},"/docs/v7/migrating","docs/91.v7/17.migrating",{"title":407,"path":408,"stem":409},"API 参考","/docs/v7/api","docs/91.v7/18.api",{"page":411,"surround":1049},{"id":412,"title":89,"body":413,"description":1043,"extension":1044,"features":1045,"hero":1045,"links":1045,"meta":1046,"navigation":1045,"path":90,"seo":1047,"stem":91,"__hash__":1048},"docs/docs/02.guide/16.server-side-translations.md",{"type":414,"value":415,"toc":1038},"minimal",[416,420,432,437,440,458,461,808,811,818,821,888,903,913,922,925,1028,1034],[417,418,419],"p",{},"您可以在服务器端进行翻译并将其作为响应返回。nuxt i18n 模块选项中定义的 locale 消息已集成，因此您只需配置 locale 检测器即可。",[421,422,425],"callout",{"icon":423,"color":424},"i-heroicons-exclamation-triangle","warning",[417,426,427,431],{},[428,429,430],"strong",{},"此功能为实验性功能，"," 从 v8 RC8 开始支持。",[433,434,436],"h2",{"id":435},"定义-locale-检测器","定义 locale 检测器",[417,438,439],{},"对于服务器端翻译，您需要定义一个 locale 检测器。",[417,441,442,443,457],{},"Nuxt i18n 导出了 ",[444,445,449,453],"code",{"className":446,"language":447,"style":448},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","ts","",[450,451,193],"span",{"class":452},"s2Zo4",[450,454,456],{"class":455},"sTEyZ","()"," 组合函数用于定义检测器。",[417,459,460],{},"以下是一个示例，演示如何定义一个使用查询、cookie 和头部检测 locale 的检测器：",[462,463,466],"pre",{"className":446,"code":464,"filename":465,"language":447,"meta":448,"style":448},"// 根据查询、cookie、头部进行检测\nexport default defineI18nLocaleDetector((event, config) => {\n  // 尝试从查询中获取 locale\n  const query = tryQueryLocale(event, { lang: '' }) // 使用 `lang` 选项禁用 locale 的默认值\n  if (query) {\n    return query.toString()\n  }\n\n  // 尝试从 cookie 中获取 locale\n  const cookie = tryCookieLocale(event, { lang: '', name: 'i18n_redirected' }) // 使用 `lang` 选项禁用 locale 的默认值\n  if (cookie) {\n    return cookie.toString()\n  }\n\n  // 尝试从头部 (`accept-header`) 中获取 locale\n  const header = tryHeaderLocale(event, { lang: '' }) // 使用 `lang` 选项禁用 locale 的默认值\n  if (head