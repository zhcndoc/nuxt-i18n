onfig"," 中配置，并且与 Nuxt I18n 使用或提供的功能没有重叠。",[539,603,605],{"id":604},"添加-vue-i18n-配置文件","添加 Vue I18n 配置文件",[543,607,608,609,612,613,616],{},"要配置选项，可以在 ",[553,610,611],{},"\u003CrootDir>/i18n"," 目录中创建一个 ",[553,614,615],{},"i18n.config.ts"," 文件，该文件应具有一个默认导出，返回 Vue I18n 选项的函数。",[543,618,619,620,622],{},"Nuxt I18n 提供了一个宏函数 ",[553,621,185],{}," 来改善类型，但一个普通的函数也足够：",[624,625,631],"pre",{"className":626,"code":627,"filename":628,"language":629,"meta":630,"style":630},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","export default defineI18nConfig(() => {\n  return {\n    // vue-i18n 选项\n  }\n})\n","i18n/i18n.config.ts","ts","",[553,632,633,664,672,679,685],{"__ignoreMap":630},[634,635,638,642,645,649,653,657,661],"span",{"class":636,"line":637},"line",1,[634,639,641],{"class":640},"s7zQu","export",[634,643,644],{"class":640}," default",[634,646,648],{"class":647},"s2Zo4"," defineI18nConfig",[634,650,652],{"class":651},"sTEyZ","(",[634,654,656],{"class":655},"sMK4o","()",[634,658,660],{"class":659},"spNyl"," =>",[634,662,663],{"class":655}," {\n",[634,665,667,670],{"class":636,"line":666},2,[634,668,669],{"class":640},"  return",[634,671,663],{"class":655},[634,673,675],{"class":636,"line":674},3,[634,676,678],{"class":677},"sHwdD","    // vue-i18n 选项\n",[634,680,682],{"class":636,"line":681},4,[634,683,684],{"class":655},"  }\n",[634,686,688,691],{"class":636,"line":687},5,[634,689,690],{"class":655},"}",[634,692,693],{"class":651},")\n",[543,695,696,697,699,700,703,704,707],{},"配置文件从 ",[553,698,611],{}," 解析，并自动查找并加载以默认文件名 ",[553,701,702],{},"i18n.config"," 的配置文件。可以使用 ",[553,705,706],{},"vueI18n"," 选项进行配置。",[539,709,710],{"id":710},"何时使用",[543,712,713,714,716],{},"当需要配置涉及不能序列化为构建时处理的运行时函数或数据的 Vue I18n 选项时，请使用 ",[553,715,615],{},"。通常在以下情况下需要这样做：",[547,718,719,722,725],{},[550,720,721],{},"需要根据用户输入或外部 API 动态加载或操控本地化数据。",[550,723,724],{},"使用自定义格式化函数或其他不可序列化的选项。",[550,726,727],{},"需要使用 Nuxt I18n 的构建时配置不支持的 Vue I18n 选项。",[539,729,731],{"id":730},"nuxt-配置的好处","Nuxt 配置的好处",[543,733,734,735,738,739,742,743,746,747,750,751,753,754,757],{},"虽然可以配置相同的（或功能上相同的）选项在 ",[553,736,737],{},"nuxt.config.ts"," 中（例如 ",[553,740,741],{},"messages"," - 代替 ",[553,744,745],{},"locales",", ",[553,748,749],{},"defaultLocale"," 等），但建议尽量将 Nuxt I18n 支持的配置保留在 ",[553,752,600],{}," 内的 ",[553,755,756],{},"i18n"," 关键字上。",[543,759,760,761,764],{},"Nuxt I18n 会在构建步骤中使用这些选项，并通过与其他库（如 ",[553,762,763],{},"@intlify/unplugin-vue-i18n","）集成来配置和优化功能。",[543,766,767],{},"Vue I18n 配置文件将在每个请求的运行时加载，这可能会增加服务器响应时间，特别是在高流量应用程序中。这是因为服务器需要为每个传入请求解析和处理配置，并将其与 Nuxt I18n 设置的配置合并，而不是在构建时一次性完成。",[769,770,771],"style",{},"html pre.shiki code .s7zQu, html code.shiki .s7zQu{--shiki-light:#39ADB5;--shiki-light-font-style:italic;--shiki-default:#89DDFF;--shiki-default-font-style:italic;--shiki-dark:#89DDFF;--shiki-dark-font-style:italic}html pre.shiki code .s2Zo4, html code.shiki .s2Zo4{--shiki-light:#6182B8;--shiki-default:#82AAFF;--shiki-dark:#82AAFF}html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--shiki-dark:#BABED8}html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .spNyl, html code.shiki .spNyl{--shiki-light:#9C3EDA;--shiki-default:#C792EA;--shiki-dark:#C792EA}html pre.shiki code .sHwdD, html code.shiki .sHwdD{--shiki-light:#90A4AE;--shiki-light-font-style:italic;--shiki-default:#546E7A;--shiki-default-font-style:italic;--shiki-dark:#676E95;--shiki-dark-font-style:italic}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html 