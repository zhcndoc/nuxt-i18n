ges",{"title":97,"path":404,"stem":405},"/docs/v7/migrating","docs/91.v7/17.migrating",{"title":407,"path":408,"stem":409},"API 参考","/docs/v7/api","docs/91.v7/18.api",{"page":411,"surround":662},{"id":412,"title":21,"body":413,"description":656,"extension":657,"features":658,"hero":658,"links":658,"meta":659,"navigation":658,"path":22,"seo":660,"stem":23,"__hash__":661},"docs/docs/01.getting-started/03.vue-i18n.md",{"type":414,"value":415,"toc":650},"minimal",[416,420,424,462,473,480,484,495,501,572,586,589,595,606,610,636,643,646],[417,418,21],"h2",{"id":419},"vue-i18n-配置",[421,422,423],"p",{},"虽然某些选项在 Nuxt I18n 和 Vue I18n 之间是共享的，但还有一些选项是特定于 Vue I18n 的，例如：",[425,426,427,435,441,447,453,459],"ul",{},[428,429,430,434],"li",{},[431,432,433],"code",{},"fallbackWarn",": 控制回退警告。",[428,436,437,440],{},[431,438,439],{},"missingWarn",": 控制缺失本地化警告。",[428,442,443,446],{},[431,444,445],{},"formatter",": 提供自定义消息格式化函数。",[428,448,449,452],{},[431,450,451],{},"numberFormats",": 配置自定义数字格式。",[428,454,455,458],{},[431,456,457],{},"datetimeFormats",": 配置自定义日期时间格式。",[428,460,461],{},"... 更多！",[421,463,464,465,472],{},"这些只是 Vue I18n 中可用运行时选项的一些示例，请查看 ",[466,467,471],"a",{"href":468,"rel":469},"https://vue-i18n.intlify.dev/",[470],"nofollow","Vue I18n 的文档"," 以探索可用选项的完整范围。",[421,474,475,476,479],{},"Vue I18n 特定选项不能在 ",[431,477,478],{},"nuxt.config"," 中配置，并且与 Nuxt I18n 使用或提供的功能没有重叠。",[417,481,483],{"id":482},"添加-vue-i18n-配置文件","添加 Vue I18n 配置文件",[421,485,486,487,490,491,494],{},"要配置选项，可以在 ",[431,488,489],{},"\u003CrootDir>/i18n"," 目录中创建一个 ",[431,492,493],{},"i18n.config.ts"," 文件，该文件应具有一个默认导出，返回 Vue I18n 选项的函数。",[421,496,497,498,500],{},"Nuxt I18n 提供了一个宏函数 ",[431,499,185],{}," 来改善类型，但一个普通的函数也足够：",[502,503,509],"pre",{"className":504,"code":505,"filename":506,"language":507,"meta":508,"style":508},"language-ts shiki shiki-themes material-theme-lighter material-theme material-theme-palenight","export default defineI18nConfig(() => {\n  return {\n    // vue-i18n 选项\n  }\n})\n","i18n/i18n.config.ts","ts","",[431,510,511,542,550,557,563],{"__ignoreMap":508},[512,513,516,520,523,527,531,535,539],"span",{"class":514,"line":515},"line",1,[512,517,519],{"class":518},"s7zQu","export",[512,521,522],{"class":518}," default",[512,524,526],{"class":525},"s2Zo4"," defineI18nConfig",[512,528,530],{"class":529},"sTEyZ","(",[512,532,534],{"class":533},"sMK4o","()",[512,536,538],{"class":537},"spNyl"," =>",[512,540,541],{"class":533}," {\n",[512,543,545,548],{"class":514,"line":544},2,[512,546,547],{"class":518},"  return",[512,549,541],{"class":533},[512,551,553],{"class":514,"line":552},3,[512,554,556],{"class":555},"sHwdD","    // vue-i18n 选项\n",[512,558,560],{"class":514,"line":559},4,[512,561,562],{"class":533},"  }\n",[512,564,566,569],{"class":514,"line":565},5,[512,567,568],{"class":533},"}",[512,570,571],{"class":529},")\n",[421,573,574,575,577,578,581,582,585],{},"配置文件从 ",[431,576,489],{}," 解析，并自动查找并加载以默认文件名 ",[431,579,580],{},"i18n.config"," 的配置文件。可以使用 ",[431,583,584],{},"vueI18n"," 选项进行配置。",[417,587,588],{"id":588},"何时使用",[421,590,591,592,594],{},"当需要配置涉及不能序列化为构建时处理的运行时函数或数据的 Vue I18n 选项时，请使用 ",[431,593,493],{},"。通常在以下情况下需要这样做：",[425,596,597,600,603],{},[428,598,599],{},"需要根据用户输入或外部 API 动态加载或操控本地化数据。",[428,601,602],{},"使用自定义格式化函数或其他不可序列化的选项。",[428,604,605],{},"需要使用 Nuxt I18n 的构建时配置不支持的 Vue I18n 选项。",[417,607,609],{"id":608},"nuxt-配置的好处","Nuxt 配置的好处",[421,611,612,613,616,617,620,621,624,625,628,629,631,632,635],{},"虽然可以配置相同的（或功能上相同的）选项在 ",[431,614,615],{},"nuxt.config.ts"," 中（例如 ",[431,618,619],{},"messages"," - 代替 ",[431,622,623],{},"locales",", ",[431,626,627],{},"defaultLocale"," 等），但建议尽量将 Nuxt I18n 支持的配置保留在 ",[431,630,478],{}," 内的 ",[431,633,634],{},"i18n"," 关键字上。",[421,637,638,639,642],{},"Nuxt I18n 会在构建步骤中使用这些选项，并通过与其他库（如 ",[431,640,641],{},"@intlify/unplugin-vue-i18n","）集成来配置和优化功能。",[421,644,645],{},"Vue I18n 配置文件将在每个请求的运行时加载，这可能会增加服务器响应时间，特别是在高流量应用程序中。这是因为服务器需要为每个传入请求解析和处理配置，并将其与 Nuxt I18n 设置的配置合并，而不是在构建时一次性完成。",[647,648,649],"style",{},"html pre.shik