2,1072,1043],{"class":669},[652,1074,1075],{"class":673},"}`",[652,1077,896],{"class":680},[652,1079,1080,1082],{"class":654,"line":701},[652,1081,893],{"class":673},[652,1083,896],{"class":669},[625,1085,1086],{"id":1086},"多文件懒加载",[539,1088,1089,1091],{},[561,1090,593],{}," 属性可以用来懒加载多个文件。",[539,1093,1094],{},"这非常有用，因为管理多个仅定义差异的文件是高效的，而无需重复区域消息。",[539,1096,1097,1098,1104,1105,1108],{},"例如，假设支持西班牙语。根据 ",[570,1099,1103],{"href":1100,"rel":1101},"https://en.wikipedia.org/wiki/Spanish_language#Geographical_distribution",[1102],"nofollow","维基百科","，西班牙语是 ",[543,1106,1107],{},"20 个国家"," 的官方语言！",[539,1110,1111,1112,1114],{},"如果这些国家都使用 ",[561,1113,589],{}," 进行配置，由于每个国家的区域消息重复，将难以维护。",[539,1116,1117],{},"在这种情况下，将所有共享（公共）区域消息保存在一个单独的文件中，并分别定义每个国家的方言变体以防止重复，将更容易维护。",[539,1119,1120],{},"以下是一个包含西班牙语区域文件的 lang 目录的示例：",[631,1122,1125],{"className":1123,"code":1124,"language":636},[634],"nuxt-project/\n├── lang/\n│   ├── es.json     # 西班牙语的公共区域消息\n│   ├── es-AR.json  # 阿根廷的区域消息\n│   ├── es-UY.json  # 乌拉圭的区域消息\n│   ├── es-US.json  # 美国的区域消息\n|   ...             # 其他国家 ...\n├── nuxt.config.ts\n",[561,1126,1124],{"__ignoreMap":639},[539,1128,1129,1130,1132],{},"以下是 ",[561,1131,647],{}," 中配置的示例：",[631,1134,1136],{"className":645,"code":1135,"filename":647,"language":648,"meta":639,"style":639},"export default defineNuxtConfig({\n  i18n: {\n    locales: [\n      /**\n       * 面向西班牙语国家的示例定义，使用 `files`\n       */\n      {\n        code: 'es-AR',\n        name: 'Español (Argentina)',\n        // 懒加载顺序: `es.json` -> `es-AR.json`，然后将 'es-AR.json' 与 'es.json' 合并\n        files: ['es.json', 'es-AR.json']\n      },\n      {\n        code: 'es-UY',\n        name: 'Español (Uruguay)',\n        // 懒加载顺序: `es.json` -> `es-UY.json`，然后将 'es-UY.json' 与 'es.json' 合并\n        files: ['es.json', 'es-UY.json']\n      },\n      {\n        code: 'es-US',\n        name: 'Español (Estados Unidos)',\n        // 懒加载顺序: `es.json` -> `es-US.json`，然后将 'es-US.json' 与 'es.json' 合并\n        files: ['es.json', 'es-US.json']\n      }\n    ],\n    lazy: true,\n    langDir: 'lang',\n    defaultLocale: 'en'\n  }\n})\n",[561,1137,1138,1150,1158,1166,1171,1176,1181,1185,1200,1216,1221,1251,1255,1259,1274,1289,1294,1319,1323,1327,1342,1357,1363,1389,1394,1401,1412,1427,1440,1445],{"__ignoreMap":639},[652,1139,1140,1142,1144,1146,1148],{"class":654,"line":655},[652,1141,659],{"class":658},[652,1143,662],{"class":658},[652,1145,666],{"class":665},[652,1147,670],{"class":669},[652,1149,674],{"class":673},[652,1151,1152,1154,1156],{"class":654,"line":677},[652,1153,681],{"class":680},[652,1155,684],{"class":673},[652,1157,687],{"class":673},[652,1159,1160,1162,1164],{"class":654,"line":690},[652,1161,693],{"class":680},[652,1163,684],{"class":673},[652,1165,698],{"class":669},[652,1167,1168],{"class":654,"line":701},[652,1169,1170],{"class":968},"      /**\n",[652,1172,1173],{"class":654,"line":707},[652,1174,1175],{"class":968},"       * 面向西班牙语国家的示例定义，使用 `files`\n",[652,1177,1178],{"class":654,"line":728},[652,1179,1180],{"class":968},"       */\n",[652,1182,1183],{"class":654,"line":744},[652,1184,704],{"class":673},[652,1186,1187,1189,1191,1193,1196,1198],{"class":654,"line":750},[652,1188,710],{"class":680},[652,1190,684],{"class":673},[652,1192,715],{"class":673},[652,1194,1195],{"class":718},"es-AR",[652,1197,722],{"class":673},[652,1199,725],{"class":673},[652,1201,1202,1205,1207,1209,1212,1214],{"class":654,"line":755},[652,1203,1204],{"class":680},"        name",[652,1206,684],{"class":673},[652,1208,715],{"class":673},[652,1210,1211],{"class":718},"Español (Argentina)",[652,1213,722],{"class":673},[652,1215,725],{"class":673},[652,1217,1218],{"class":654,"line":771},[652,1219,1220],{"class":968},"        // 懒加载顺序: `es.json` -> `es-AR.json`，然后将 'es-AR.json' 与 'es.json' 合并\n",[652,1222,1223,1226,1228,1231,1233,1236,1238,1241,1243,1246,1248],{"class":654,"line":785},[652,1224,1225],{"class":680},"        files",[652,1227,684],{"class":673},[652,1229,1230],{"class":669}," [",[652,1232