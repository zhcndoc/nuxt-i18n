2,891],"callout",{"icon":881},"i-heroicons-light-bulb",[417,883,884,885,501],{},"如果您的函数返回一个区域消息对象，",[421,886,887,888,890],{},"您必须在 ",[439,889,189],{}," 组合函数中定义它",[417,892,893,894,896,897,501],{},"关于 ",[439,895,189],{}," 的详细信息，请见 ",[448,898,900],{"href":899},"/docs/v8/api#defineI18nLocale","这里",[417,902,903],{},"如果函数返回一个在 nuxt i18n 模块中可用的对象，您可以通过 fetch 配置动态区域消息，例如 API（包括外部 API）或后端：",[509,905,907],{"className":523,"code":906,"language":526,"meta":517,"style":517},"export default defineI18nLocale(locale => {\n  // 例如，从 nuxt 服务器获取区域消息\n  return $fetch(`/api/${locale}`)\n})\n",[439,908,909,926,931,956],{"__ignoreMap":517},[530,910,911,913,915,917,919,922,924],{"class":532,"line":533},[530,912,537],{"class":536},[530,914,540],{"class":536},[530,916,789],{"class":543},[530,918,548],{"class":547},[530,920,921],{"class":798},"locale",[530,923,802],{"class":794},[530,925,565],{"class":551},[530,927,928],{"class":532,"line":555},[530,929,930],{"class":846},"  // 例如，从 nuxt 服务器获取区域消息\n",[530,932,933,935,938,940,943,946,949,951,954],{"class":532,"line":568},[530,934,809],{"class":536},[530,936,937],{"class":543}," $fetch",[530,939,548],{"class":558},[530,941,942],{"class":551},"`",[530,944,945],{"class":596},"/api/",[530,947,948],{"class":551},"${",[530,950,921],{"class":547},[530,952,953],{"class":551},"}`",[530,955,774],{"class":558},[530,957,958,960],{"class":532,"line":579},[530,959,771],{"class":551},[530,961,774],{"class":547},[503,963,964],{"id":964},"多文件懒加载",[417,966,967,969],{},[439,968,471],{}," 属性可以用来懒加载多个文件。",[417,971,972],{},"这非常有用，因为管理多个仅定义差异的文件是高效的，而无需重复区域消息。",[417,974,975,976,982,983,986],{},"例如，假设支持西班牙语。根据 ",[448,977,981],{"href":978,"rel":979},"https://en.wikipedia.org/wiki/Spanish_language#Geographical_distribution",[980],"nofollow","维基百科","，西班牙语是 ",[421,984,985],{},"20 个国家"," 的官方语言！",[417,988,989,990,992],{},"如果这些国家都使用 ",[439,991,467],{}," 进行配置，由于每个国家的区域消息重复，将难以维护。",[417,994,995],{},"在这种情况下，将所有共享（公共）区域消息保存在一个单独的文件中，并分别定义每个国家的方言变体以防止重复，将更容易维护。",[417,997,998],{},"以下是一个包含西班牙语区域文件的 lang 目录的示例：",[509,1000,1003],{"className":1001,"code":1002,"language":514},[512],"nuxt-project/\n├── lang/\n│   ├── es.json     # 西班牙语的公共区域消息\n│   ├── es-AR.json  # 阿根廷的区域消息\n│   ├── es-UY.json  # 乌拉圭的区域消息\n│   ├── es-US.json  # 美国的区域消息\n|   ...             # 其他国家 ...\n├── nuxt.config.ts\n",[439,1004,1002],{"__ignoreMap":517},[417,1006,1007,1008,1010],{},"以下是 ",[439,1009,525],{}," 中配置的示例：",[509,1012,1014],{"className":523,"code":1013,"filename":525,"language":526,"meta":517,"style":517},"export default defineNuxtConfig({\n  i18n: {\n    locales: [\n      /**\n       * 面向西班牙语国家的示例定义，使用 `files`\n       */\n      {\n        code: 'es-AR',\n        name: 'Español (Argentina)',\n        // 懒加载顺序: `es.json` -> `es-AR.json`，然后将 'es-AR.json' 与 'es.json' 合并\n        files: ['es.json', 'es-AR.json']\n      },\n      {\n        code: 'es-UY',\n        name: 'Español (Uruguay)',\n        // 懒加载顺序: `es.json` -> `es-UY.json`，然后将 'es-UY.json' 与 'es.json' 合并\n        files: ['es.json', 'es-UY.json']\n      },\n      {\n        code: 'es-US',\n        name: 'Español (Estados Unidos)',\n        // 懒加载顺序: `es.json` -> `es-US.json`，然后将 'es-US.json' 与 'es.json' 合并\n        files: ['es.json', 'es-US.json']\n      }\n    ],\n    lazy: true,\n    langDir: 'lang',\n    defaultLocale: 'en'\n  }\n})\n",[439,1015,1016,1028,1036,1044,1049,1054,1059,1063,1078,1094,1099,1129,1133,1137,1152,1167,1172,1197,1201,1205,1220,1235,1241,1267,1272,1279,1290,1305,1318,1323],{"__ignoreMap":517},[530,1017,1018,1020,1022,1024,1026],{"class":532,"line":533},[530,1019,537],{"class":536},[530,1021,540],{"class":536},[530,1023,544],{"class":543},[530,1025,548],{"class":547},[530,1027,552],{"class":551},[530,1029,1030,1032,1034],{"class":532,"line":555},[530,1031,559],{"class":558},[530,1033,562],{"class":551},[530,1035,565],{"class":551},[530,1037,1038,1040,1042],{"class":532,"line":568},[530,1039,571],{"class":558},[530,1041,562],{"class":551},[530,1043,576],{"class":547},[530,1045,1046],{"cla