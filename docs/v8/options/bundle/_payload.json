h-feature-build-flags",[595],"nofollow","这里","。",[599,600,603,616],"callout",{"icon":601,"color":602},"i-heroicons-exclamation-triangle","warning",[562,604,605,606,608,609,597,612,597],{},"如果您希望使用 Vue I18n 的遗留 API，必须将 ",[543,607,574],{}," 设置为 ",[543,610,611],{},"false",[613,614,615],"strong",{},"请注意，设置此值将禁用 Vue I18n 组合 API",[562,617,618,619,622,623,597],{},"注意，通过在 i18n.config 中将 Vue I18n 选项设置为 ",[543,620,621],{},"allowComposition: true","，也可以以混合方式使用遗留 API，但这有一定限制。有关详细信息，请参见 ",[591,624,596],{"href":625,"rel":626},"https://vue-i18n.intlify.dev/guide/migration/vue3.html",[595],[569,628,630],{"id":629},"runtimeonly",[543,631,632],{},"runtimeOnly",[546,634,635,639],{},[549,636,551,637],{},[543,638,581],{},[549,640,557,641],{},[543,642,611],{},[562,644,645],{},"在构建中是否自动使用 Vue I18n 运行时（runtime-only）。",[599,647,648],{"icon":601,"color":602},[562,649,650,651,597],{},"当您启用此选项时，vue-i18n 消息编译器将不被捆绑。这意味着您将无法从后端 API 动态检索用于应用程序的区域消息，或者以编程方式组合区域消息。也就是说，",[613,652,653],{},"您必须能够在构建时完全解析区域消息",[569,655,657],{"id":656},"fullinstall",[543,658,659],{},"fullInstall",[546,661,662,666],{},[549,663,551,664],{},[543,665,581],{},[549,667,557,668],{},[543,669,586],{},[562,671,672,673,675,676,679,680,683,684,687,688,691,692,597],{},"是否安装完整的 API、组件等。默认情况下，所有组件将被安装。如果指定为 ",[543,674,611],{},"，内置组件（",[543,677,678],{},"i18n-t","、",[543,681,682],{},"i18n-d"," 和 ",[543,685,686],{},"i18n-n","）和指令（",[543,689,690],{},"v-t","）将在 Vue 中不被安装，并且将被冻结（tree-shaken）。有关更多详细信息，请参见 ",[591,693,596],{"href":593,"rel":694},[595],[569,696,698],{"id":697},"dropmessagecompiler",[543,699,700],{},"dropMessageCompiler",[546,702,703,707],{},[549,704,551,705],{},[543,706,581],{},[549,708,557,709],{},[543,710,611],{},[562,712,713],{},"在捆绑时是否去除消息编译器。",[599,715,717],{"icon":716},"i-heroicons-light-bulb",[562,718,719,720,723],{},"如果使用此选项，您需要启用 ",[543,721,722],{},"compilation.jit"," 选项。",[599,725,726],{"icon":601,"color":602},[562,727,728,729,732],{},"如果您启用此选项，",[613,730,731],{},"您应该检查应用程序中的资源是否与 nuxt i18n 模块进行预编译","。如果您将通过 API 从后端动态加载资源，启用此选项将无法工作，因为没有消息编译器。",[569,734,736],{"id":735},"onlylocales",[543,737,738],{},"onlyLocales",[546,740,741,746],{},[549,742,551,743],{},[543,744,745],{},"string | string[]",[549,747,557,748],{},[543,749,750],{},"undefined",[562,752,753],{},"指定需要包含的语言代码，其他将被移除。",[562,755,756,757,762],{},"如果您有一个代码库（例如 ",[591,758,761],{"href":759,"rel":760},"https://nuxt.com/docs/getting-started/layers",[595],"Nuxt Layers","）用于几个使用不同语言的相似项目，这将会很有用。",[599,764,765],{"icon":601,"color":602},[562,766,767,768,771],{},"此 ",[613,769,770],{},"选项的值将不会与其他 Nuxt Layers 合并","。此选项仅应在最终项目配置中指定。",{"title":773,"searchDepth":774,"depth":774,"links":775},"",2,[776],{"id":541,"depth":774,"text":541,"children":777},[778,780,781,782,783],{"id":571,"depth":779,"text":574},3,{"id":629,"depth":779,"text":632},{"id":656,"depth":779,"text":659},{"id":697,"depth":779,"text":700},{"id":735,"depth":779,"text":738},"捆绑选项。","md",null,{},{"title":307,"description":784},"TSSvR3zdu1aiiqgi7-WCPd8exNC3thmhKHH6QpxcrZA",[791,793],{"title":303,"path":304,"stem":305,"description":792,"children":-1},"Vue I18n 消息格式编译选项。",{"title":311,"path":312,"stem":313,"description":794,"children":-1},"i18n 自定义区块选项。",1747373459690]