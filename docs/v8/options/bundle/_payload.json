title":97,"path":404,"stem":405},"/docs/v7/migrating","docs/91.v7/17.migrating",{"title":407,"path":408,"stem":409},"API 参考","/docs/v7/api","docs/91.v7/18.api",{"page":411,"surround":668},{"id":412,"title":307,"body":413,"description":662,"extension":663,"features":664,"hero":664,"links":664,"meta":665,"navigation":664,"path":308,"seo":666,"stem":309,"__hash__":667},"docs/docs/90.v8/3.options/07.bundle.md",{"type":414,"value":415,"toc":650},"minimal",[416,423,439,443,446,453,465,476,505,511,521,524,532,538,548,573,579,589,592,602,611,617,629,632,641],[417,418,420],"h2",{"id":419},"bundle",[421,422,419],"code",{},[424,425,426,433],"ul",{},[427,428,429,430],"li",{},"type: ",[421,431,432],{},"object",[427,434,435,436],{},"default: ",[421,437,438],{},"{ compositionOnly: true, runtimeOnly: false, fullInstall: true, dropMessageCompiler: false }",[440,441,442],"p",{},"配置 nuxt i18n 模块的捆绑优化。",[440,444,445],{},"支持的属性：",[447,448,450],"h3",{"id":449},"compositiononly",[421,451,452],{},"compositionOnly",[424,454,455,460],{},[427,456,429,457],{},[421,458,459],{},"boolean",[427,461,435,462],{},[421,463,464],{},"true",[440,466,467,468,475],{},"是否仅使用 vue-i18n 的组合 API。默认情况下，遗留 API 会被树摇（tree-shaken）。有关更多详细信息，请参见 ",[469,470,474],"a",{"href":471,"rel":472},"https://vue-i18n.intlify.dev/guide/advanced/optimization.html#reduce-bundle-size-with-feature-build-flags",[473],"nofollow","这里","。",[477,478,481,494],"callout",{"icon":479,"color":480},"i-heroicons-exclamation-triangle","warning",[440,482,483,484,486,487,475,490,475],{},"如果您希望使用 Vue I18n 的遗留 API，必须将 ",[421,485,452],{}," 设置为 ",[421,488,489],{},"false",[491,492,493],"strong",{},"请注意，设置此值将禁用 Vue I18n 组合 API",[440,495,496,497,500,501,475],{},"注意，通过在 i18n.config 中将 Vue I18n 选项设置为 ",[421,498,499],{},"allowComposition: true","，也可以以混合方式使用遗留 API，但这有一定限制。有关详细信息，请参见 ",[469,502,474],{"href":503,"rel":504},"https://vue-i18n.intlify.dev/guide/migration/vue3.html",[473],[447,506,508],{"id":507},"runtimeonly",[421,509,510],{},"runtimeOnly",[424,512,513,517],{},[427,514,429,515],{},[421,516,459],{},[427,518,435,519],{},[421,520,489],{},[440,522,523],{},"在构建中是否自动使用 Vue I18n 运行时（runtime-only）。",[477,525,526],{"icon":479,"color":480},[440,527,528,529,475],{},"当您启用此选项时，vue-i18n 消息编译器将不被捆绑。这意味着您将无法从后端 API 动态检索用于应用程序的区域消息，或者以编程方式组合区域消息。也就是说，",[491,530,531],{},"您必须能够在构建时完全解析区域消息",[447,533,535],{"id":534},"fullinstall",[421,536,537],{},"fullInstall",[424,539,540,544],{},[427,541,429,542],{},[421,543,459],{},[427,545,435,546],{},[421,547,464],{},[440,549,550,551,553,554,557,558,561,562,565,566,569,570,475],{},"是否安装完整的 API、组件等。默认情况下，所有组件将被安装。如果指定为 ",[421,552,489],{},"，内置组件（",[421,555,556],{},"i18n-t","、",[421,559,560],{},"i18n-d"," 和 ",[421,563,564],{},"i18n-n","）和指令（",[421,567,568],{},"v-t","）将在 Vue 中不被安装，并且将被冻结（tree-shaken）。有关更多详细信息，请参见 ",[469,571,474],{"href":471,"rel":572},[473],[447,574,576],{"id":575},"dropmessagecompiler",[421,577,578],{},"dropMessageCompiler",[424,580,581,585],{},[427,582,429,583],{},[421,584,459],{},[427,586,435,587],{},[421,588,489],{},[440,590,591],{},"在捆绑时是否去除消息编译器。",[477,593,595],{"icon":594},"i-heroicons-light-bulb",[440,596,597,598,601],{},"如果使用此选项，您需要启用 ",[421,599,600],{},"compilation.jit"," 选项。",[477,603,604],{"icon":479,"color":480},[440,605,606,607,610],{},"如果您启用此选项，",[491,608,609],{},"您应该检查应用程序中的资源是否与 nuxt i18n 模块进行预编译","。如果您将通过 API 从后端动态加载资源，启用此选项将无法工作，因为没有消息编译器。",[447,612,614],{"id":613},"onlylocales",[421,615,616],{},"onlyLocales",[424,618,619,624],{},[427,620,429,621],{},[421,622,623],{},"string | string[]",[427,625,435,626],{},[421,627,628],{},"undefined",[440,630,631],{},"指定需要包含的语言代码，其他将被移除。",[440,633,634,635,640],{},"如果您有一个代码库（例如 ",[469,636,639],{"href":637,"rel":638},"https://nuxt.com/docs/getting-started/layers",[473],"Nuxt Layers","）用于几个使用不同语言的相似项目，这将会很有用。",[477,642,643],{"icon":479,"color":480},[440,644,645,646,649],{},"此 ",[491,647,648],{},"选项的值将不会与其他 Nuxt Layers 合并","。此选项仅应在最终项目配置中指定。",{"title":651,"searchDepth":652,"depth":652,"links":653},"",2,[654],{"id":419,"depth":652,"text":419,"children":655},[656,658,659,660,661],{"id":449,"depth":657,"text":452},3,{"id":507,"depth":657,"text":510},{"id":534,"depth":657,"text":537},{"id":575,"depth":657,"text":578},{"id":613,"depth":657,"text":616},"捆绑选项。","md",null,{},{"title":307,"description":662},"TSSvR3zdu1aiiqgi7-WCPd8exNC3thmhKHH6QpxcrZA",[669,671],{"title":303,"path":304,"stem":305,"description":670,"children":-1},"Vue I18n 消息格式编译选项。",{"title":311,"path":312,"stem":313,"description":672,"children":-1},"i18n 自定义区块选项。",1746854296734]